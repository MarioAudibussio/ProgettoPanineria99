<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MenuActivity">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tablayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rossoPulsante"
        app:tabIndicatorColor="@color/white"
        app:tabSelectedTextColor="@color/white">


        <com.google.android.material.tabs.TabItem
            android:id="@+id/panini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Pnini"/>

        <com.google.android.material.tabs.TabItem
            android:id="@+id/fritti"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Fritti"/>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/bibite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Bibite"/>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/hamburgerSpeciali"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/HamburgerSpeciali"/>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/vaschette"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Vaschette"/>

    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/framelayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>


</LinearLayout>